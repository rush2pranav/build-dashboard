<Window x:Class="BuildDashboard.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:BuildDashboard.App.ViewModels"
        Title="Build Dashboard — CI/CD Monitor" 
        Height="800" Width="1300"
        MinHeight="600" MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        Background="#0D1117">

    <Window.DataContext>
        <vm:DashboardViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <SolidColorBrush x:Key="BgPrimary" Color="#0D1117"/>
        <SolidColorBrush x:Key="BgCard" Color="#161B22"/>
        <SolidColorBrush x:Key="BgHover" Color="#21262D"/>
        <SolidColorBrush x:Key="BorderClr" Color="#30363D"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#E6EDF3"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#8B949E"/>
        <SolidColorBrush x:Key="Green" Color="#3FB950"/>
        <SolidColorBrush x:Key="Red" Color="#F85149"/>
        <SolidColorBrush x:Key="Yellow" Color="#D29922"/>
        <SolidColorBrush x:Key="Blue" Color="#58A6FF"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="MetricCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource BgCard}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderClr}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Margin" Value="4"/>
        </Style>

        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background" Value="#238636"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2EA043"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- header section -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="🔨" FontSize="24" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="Build Dashboard" FontSize="22" FontWeight="Bold" 
                           Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                <Border Background="#1F6FEB" CornerRadius="10" Padding="8,2" Margin="12,0,0,0"
                        VerticalAlignment="Center">
                    <TextBlock Text="CI/CD Monitor" Foreground="White" FontSize="11"/>
                </Border>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Project:" Foreground="{StaticResource TextSecondary}" 
                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ComboBox ItemsSource="{Binding Projects}" SelectedItem="{Binding SelectedProject}"
                          Width="140" Margin="0,0,8,0"/>
                <Button Content="▶ Trigger Build" Command="{Binding TriggerBuildCommand}"
                        Style="{StaticResource ActionBtn}" Margin="0,0,8,0"/>
                <Button Content="↻ Refresh" Command="{Binding RefreshCommand}"
                        Style="{StaticResource ActionBtn}" Background="#21262D"/>
            </StackPanel>
        </Grid>

        <!-- cards used for the metrics -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource MetricCard}">
                <StackPanel>
                    <TextBlock Text="Total Builds" Foreground="{StaticResource TextSecondary}" FontSize="11"/>
                    <TextBlock Text="{Binding TotalBuilds}" Foreground="{StaticResource TextPrimary}" 
                               FontSize="28" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource MetricCard}">
                <StackPanel>
                    <TextBlock Text="Success Rate" Foreground="{StaticResource TextSecondary}" FontSize="11"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding SuccessRate, StringFormat={}{0:F1}}" 
                                   Foreground="{StaticResource Green}" FontSize="28" FontWeight="Bold"/>
                        <TextBlock Text="%" Foreground="{StaticResource Green}" FontSize="16" 
                                   VerticalAlignment="Bottom" Margin="2,0,0,4"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource MetricCard}">
                <StackPanel>
                    <TextBlock Text="Succeeded" Foreground="{StaticResource TextSecondary}" FontSize="11"/>
                    <TextBlock Text="{Binding SuccessCount}" Foreground="{StaticResource Green}" 
                               FontSize="28" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="3" Style="{StaticResource MetricCard}">
                <StackPanel>
                    <TextBlock Text="Failed" Foreground="{StaticResource TextSecondary}" FontSize="11"/>
                    <TextBlock Text="{Binding FailedCount}" Foreground="{StaticResource Red}" 
                               FontSize="28" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="4" Style="{StaticResource MetricCard}">
                <StackPanel>
                    <TextBlock Text="Running" Foreground="{StaticResource TextSecondary}" FontSize="11"/>
                    <TextBlock Text="{Binding RunningCount}" Foreground="{StaticResource Yellow}" 
                               FontSize="28" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="5" Style="{StaticResource MetricCard}">
                <StackPanel>
                    <TextBlock Text="Avg Duration" Foreground="{StaticResource TextSecondary}" FontSize="11"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding AvgDuration, StringFormat={}{0:F0}}" 
                                   Foreground="{StaticResource Blue}" FontSize="28" FontWeight="Bold"/>
                        <TextBlock Text="s" Foreground="{StaticResource Blue}" FontSize="14" 
                                   VerticalAlignment="Bottom" Margin="2,0,0,4"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- details and the build lists -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="500"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="350"/>
            </Grid.ColumnDefinitions>

            <!-- build list section -->
            <Border Grid.Column="0" Background="{StaticResource BgCard}" CornerRadius="8"
                    BorderBrush="{StaticResource BorderClr}" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Recent Builds" Grid.Row="0" FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}" Margin="16,12"/>

                    <ListView Grid.Row="1" ItemsSource="{Binding Builds}" 
                              SelectedItem="{Binding SelectedBuild}"
                              Background="Transparent" BorderThickness="0"
                              Foreground="{StaticResource TextPrimary}">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Build" Width="70">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding BuildNumber}" Foreground="#58A6FF" FontSize="12"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Status" Width="75">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Status}" FontSize="12" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#8B949E"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Success">
                                                                <Setter Property="Foreground" Value="#3FB950"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Failed">
                                                                <Setter Property="Foreground" Value="#F85149"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Running">
                                                                <Setter Property="Foreground" Value="#D29922"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Project" Width="110">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding ProjectName}" Foreground="#E6EDF3" FontSize="12"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Branch" Width="130">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Branch}" Foreground="#8B949E" FontSize="11"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Commit" Width="180">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding CommitMessage}" Foreground="#8B949E" FontSize="11"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Duration" Width="70">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DurationSeconds, StringFormat={}{0:F0}s}" 
                                                       Foreground="#8B949E" FontSize="11"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="3" Background="{StaticResource BorderClr}"
                          HorizontalAlignment="Center" VerticalAlignment="Stretch"/>

            <!-- build details section -->
            <Border Grid.Column="2" Background="{StaticResource BgCard}" CornerRadius="8"
                    BorderBrush="{StaticResource BorderClr}" BorderThickness="1" Padding="16">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Build Details" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimary}" Margin="0,0,0,12"/>

                        <!-- if no selection -->
                        <TextBlock Text="Select a build to view details" FontStyle="Italic"
                                   Foreground="{StaticResource TextSecondary}" FontSize="12"
                                   Visibility="{Binding HasSelectedBuild, Converter={StaticResource BoolToVis}, 
                                               ConverterParameter=Inverse, FallbackValue=Visible}"/>

                        <!-- selected build details -->
                        <StackPanel Visibility="{Binding HasSelectedBuild, Converter={StaticResource BoolToVis}}">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="{Binding SelectedBuild.BuildNumber}" FontSize="18" 
                                           FontWeight="Bold" Foreground="{StaticResource Blue}" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding SelectedBuild.Status}" FontSize="16" FontWeight="SemiBold"
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#8B949E"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedBuild.Status}" Value="Success">
                                                    <Setter Property="Foreground" Value="#3FB950"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SelectedBuild.Status}" Value="Failed">
                                                    <Setter Property="Foreground" Value="#F85149"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>

                            <Border Background="#21262D" CornerRadius="6" Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="0,0,0,4">
                                        <Run Text="Project: "/><Run Text="{Binding SelectedBuild.ProjectName}" Foreground="{StaticResource TextPrimary}"/>
                                    </TextBlock>
                                    <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="0,0,0,4">
                                        <Run Text="Branch: "/><Run Text="{Binding SelectedBuild.Branch}" Foreground="{StaticResource TextPrimary}"/>
                                    </TextBlock>
                                    <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="0,0,0,4">
                                        <Run Text="Trigger: "/><Run Text="{Binding SelectedBuild.TriggerType}" Foreground="{StaticResource TextPrimary}"/>
                                        <Run Text=" by "/><Run Text="{Binding SelectedBuild.TriggerBy}" Foreground="{StaticResource Blue}"/>
                                    </TextBlock>
                                    <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="0,0,0,4">
                                        <Run Text="Commit: "/><Run Text="{Binding SelectedBuild.CommitHash}" Foreground="{StaticResource Yellow}" FontFamily="Consolas"/>
                                    </TextBlock>
                                    <TextBlock Text="{Binding SelectedBuild.CommitMessage}" 
                                               Foreground="{StaticResource TextPrimary}" FontSize="12"
                                               TextWrapping="Wrap" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- build Steps -->
                            <TextBlock Text="Build Steps" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondary}" Margin="0,0,0,8"/>

                            <ItemsControl ItemsSource="{Binding SelectedBuild.Steps}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#21262D" CornerRadius="4" 
                                                Padding="10,6" Margin="0,0,0,4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" FontSize="12" Margin="0,0,8,0"
                                                           VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="⏳"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="Success">
                                                                    <Setter Property="Text" Value="✅"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Failed">
                                                                    <Setter Property="Text" Value="❌"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Skipped">
                                                                    <Setter Property="Text" Value="⏭️"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Running">
                                                                    <Setter Property="Text" Value="🔄"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock Grid.Column="1" Text="{Binding StepName}" 
                                                           Foreground="#E6EDF3" FontSize="12" 
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="2" 
                                                           Text="{Binding DurationSeconds, StringFormat={}{0:F1}s}" 
                                                           Foreground="#8B949E" FontSize="11"
                                                           VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- status bar section -->
        <Border Grid.Row="3" Margin="0,8,0,0">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Ellipse Width="8" Height="8" Margin="0,0,6,0" VerticalAlignment="Center">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{StaticResource Red}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                        <Setter Property="Fill" Value="{StaticResource Green}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource TextSecondary}" FontSize="11"/>
                </StackPanel>
                <TextBlock Text="Build Dashboard v1.0" Foreground="{StaticResource TextSecondary}" 
                           FontSize="11" HorizontalAlignment="Right"/>
            </Grid>
        </Border>
    </Grid>
</Window>